{
  "name": "OpenFactory-Test — Minimal Dev Container to test OpenFactory release",
  "image": "ghcr.io/openfactoryio/devcontainer",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2.16.0": {},
    "ghcr.io/openfactoryio/openfactory-sdk/infra:0.5.1": {},
    "ghcr.io/openfactoryio/openfactory-sdk/opcua-connector:0.5.1": {}
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash"
      },
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "containerEnv": {
    "OPENFACTORY_UNS_SCHEMA": "/workspaces/openfactory-test/ressources/uns.yml"
  }
}
